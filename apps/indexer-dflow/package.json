{
  "name": "indexer-dflow",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx src/main.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/main.js",
    "test": "node dist/mappers-tests.js",
    "category:backfill": "tsx src/category-backfill.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint .",
    "format": "prettier -w . --ignore-path ../../.gitignore --ignore-unknown",
    "format:check": "prettier -c . --ignore-path ../../.gitignore --ignore-unknown"
  },
  "dependencies": {
    "@hunch/db": "workspace:*",
    "@hunch/infra": "workspace:*",
    "@hunch/shared": "workspace:*",
    "fast-json-stable-stringify": "^2.1.0",
    "p-queue": "^8.0.1",
    "pg": "^8.16.3",
    "redis": "^4.7.0",
    "undici": "^6.19.8",
    "uuid": "^9.0.1",
    "ws": "^8.18.0",
    "zod": "^3.23.8"
  }
}
