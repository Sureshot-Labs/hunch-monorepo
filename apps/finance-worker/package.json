{
  "name": "finance-worker",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx src/main.ts",
    "dev:bun": "bun --conditions=source src/main.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/main.js",
    "start:bun": "bun dist/main.js",
    "test": "tsx src/finance-worker-tests.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint .",
    "format": "prettier -w . --ignore-path ../../.gitignore --ignore-unknown",
    "format:check": "prettier -c . --ignore-path ../../.gitignore --ignore-unknown"
  },
  "dependencies": {
    "api": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^20.11.30",
    "tsx": "^4.22.4"
  }
}
