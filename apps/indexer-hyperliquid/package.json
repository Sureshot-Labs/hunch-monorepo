{
  "name": "indexer-hyperliquid",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "predev": "pnpm -C ../../packages/db build",
    "dev": "tsx src/main.ts",
    "prestart": "pnpm -C ../../packages/db build",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/main.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "pnpm run build && node dist/mappers-tests.js && node dist/market-data-tests.js && node dist/bootstrap-tests.js && node dist/wsMarket-tests.js",
    "lint": "eslint .",
    "format": "prettier -w . --ignore-path ../../.gitignore --ignore-unknown",
    "format:check": "prettier -c . --ignore-path ../../.gitignore --ignore-unknown"
  },
  "dependencies": {
    "@hunch/db": "workspace:*",
    "@hunch/infra": "workspace:*",
    "@hunch/shared": "workspace:*",
    "p-queue": "^8.0.1",
    "pg": "^8.16.3",
    "ws": "^8.18.0"
  }
}
