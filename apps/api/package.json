{
  "name": "api",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "tsx src/server.ts",
    "build": "tsc -p tsconfig.json",
    "openapi:dump": "tsx src/dump-openapi.ts",
    "cleanup:expired": "tsx src/cleanup-expired-markets.ts",
    "delete-closed": "tsx src/delete-closed-markets.ts",
    "fees:collect": "tsx src/collect-fees.ts",
    "lint": "eslint .",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "format": "prettier -w . --ignore-path ../../.gitignore --ignore-unknown",
    "format:check": "prettier -c . --ignore-path ../../.gitignore --ignore-unknown"
  },
  "dependencies": {
    "@fastify/swagger": "^9.6.1",
    "@fastify/swagger-ui": "^5.2.3",
    "@hunch/contracts": "workspace:*",
    "@hunch/infra": "workspace:*",
    "@privy-io/server-auth": "^1.0.0",
    "ethers": "^6.8.1",
    "fastify": "^5.6.2",
    "fastify-type-provider-zod": "6.1.0",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.16.3",
    "zod": "4.2.0"
  },
  "devDependencies": {
    "@types/jsonwebtoken": "^9.0.5",
    "@types/node": "^20.11.30",
    "tsx": "^4.19.2"
  }
}
