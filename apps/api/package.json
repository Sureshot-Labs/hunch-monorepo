{
  "name": "api",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "tsx src/server.ts",
    "build": "tsc -p tsconfig.json",
    "cleanup:expired": "tsx src/cleanup-expired-markets.ts",
    "delete-closed": "tsx src/delete-closed-markets.ts",
    "lint": "eslint .",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "format": "prettier -w . --ignore-path ../../.gitignore --ignore-unknown",
    "format:check": "prettier -c . --ignore-path ../../.gitignore --ignore-unknown"
  },
  "dependencies": {
    "@hunch/infra": "workspace:*",
    "fastify": "^4.28.1",
    "pg": "^8.16.3",
    "jsonwebtoken": "^9.0.2",
    "ethers": "^6.8.1",
    "@privy-io/server-auth": "^1.0.0",
    "zod": "4.1.5"
  },
  "devDependencies": {
    "tsx": "^4.19.2",
    "@types/node": "^20.11.30",
    "@types/jsonwebtoken": "^9.0.5"
  }
}
