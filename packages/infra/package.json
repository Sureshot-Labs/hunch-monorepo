{
  "name": "@hunch/infra",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "prebuild": "pnpm -C ../shared run build",
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -w -p tsconfig.json",
    "dev:bun": "tsc -w -p tsconfig.json",
    "pretypecheck": "pnpm -C ../shared run build",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint .",
    "format": "prettier -w . --ignore-path ../../.gitignore --ignore-unknown",
    "format:check": "prettier -c . --ignore-path ../../.gitignore --ignore-unknown"
  },
  "dependencies": {
    "@hunch/shared": "workspace:*",
    "pg": "8.22.0",
    "redis": "^5.8.2"
  },
  "devDependencies": {
    "@types/node": "^24.13.2"
  }
}
