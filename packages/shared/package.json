{
  "name": "@hunch/shared",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "source": "./src/index.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -w -p tsconfig.json",
    "dev:bun": "tsc -w -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint .",
    "format": "prettier -w . --ignore-path ../../.gitignore --ignore-unknown",
    "format:check": "prettier -c . --ignore-path ../../.gitignore --ignore-unknown"
  },
  "dependencies": {
    "pino": "9.9.4",
    "zod": "4.1.5"
  }
}
