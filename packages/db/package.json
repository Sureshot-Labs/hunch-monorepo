{
  "name": "@hunch/db",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "source": "./src/index.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev:bun": "tsc -w -p tsconfig.build.json",
    "migrate": "tsx --tsconfig tsconfig.json src/migrate.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint .",
    "format": "prettier -w . --ignore-path ../../.gitignore --ignore-unknown",
    "format:check": "prettier -c . --ignore-path ../../.gitignore --ignore-unknown"
  },
  "dependencies": {
    "@hunch/config": "workspace:*",
    "@hunch/shared": "workspace:*",
    "globby": "^14.1.0",
    "pg": "8.22.0"
  },
  "devDependencies": {
    "@types/node": "^24.13.2",
    "@types/pg": "^8.20.0",
    "tsx": "^4.22.4",
    "typescript": "^5.9.2"
  }
}
