    "@openzeppelin/contracts": "^5.1.0",
    "hardhat": "^2.26.0",
    "typechain": "^8.3.2",
    "typescript": "^5.4.5",
    "ts-node": "^10.9.2",
    "@types/node": "^20.11.30",
    "minimist": "^1.2.8",
    "express": "^4.19.2"
  }
}
