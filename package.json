{
  "name": "hunch",
  "version": "1.0.1",
  "description": "",
  "main": "index.js",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "dev:bun": "turbo run dev:bun --parallel --filter=@hunch/config --filter=@hunch/db --filter=@hunch/infra --filter=@hunch/shared --filter=api --filter=ai-worker --filter=finance-worker --filter=indexer-dflow --filter=indexer-limitless --filter=indexer-polymarket",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "check": "pnpm typecheck && pnpm lint && pnpm test:fast",
    "test": "pnpm test:api && pnpm test:finance-worker",
    "test:api": "pnpm -F api run test",
    "test:fast": "pnpm -F api run test:fast && pnpm -F finance-worker run test",
    "test:finance-worker": "pnpm -F finance-worker run test",
    "format": "prettier -w apps packages --ignore-path .gitignore --ignore-unknown",
    "format:check": "prettier -c apps packages --ignore-path .gitignore --ignore-unknown",
    "migrate": "pnpm --filter @hunch/db migrate",
    "infra:up": "docker-compose --env-file .env -f ops/docker-compose.yml up -d postgres redis",
    "infra:down": "docker-compose --env-file .env -f ops/docker-compose.yml down",
    "logs": "docker-compose -f ops/docker-compose.yml logs -f --tail=200",
    "infra2:up": "docker compose --env-file .env -f ops/docker-compose.yml up -d postgres redis",
    "infra2:down": "docker compose --env-file .env -f ops/docker-compose.yml down",
    "infra2:logs": "docker compose -f ops/docker-compose.yml logs -f --tail=200",
    "run-db": "docker exec -it hunch-postgres psql -U hunch -d hunch",
    "psql": "node ops/psql.js",
    "psql:docker": "node ops/psql.js --docker",
    "psql:local": "node ops/psql.js --local",
    "redis": "node ops/redis.js",
    "redis:docker": "node ops/redis.js --docker",
    "redis:local": "node ops/redis.js --local",
    "smoke:api": "node ops/smoke-api.js",
    "openrouter:key": "node ops/openrouter-key.js",
    "ai:topics:matrix": "./scripts/ai-topics-matrix.sh"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/node": "^24.13.2",
    "@types/pg": "^8.20.0",
    "@types/ws": "^8.18.1",
    "eslint": "^9.39.1",
    "globals": "^15.15.0",
    "prettier": "^3.8.4",
    "tsx": "^4.22.4",
    "turbo": "2.9.18",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.62.0"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "packageManager": "pnpm@11.8.0",
  "dependencies": {
    "dotenv": "^16.6.1",
    "ethers": "^6.15.0",
    "fast-json-stable-stringify": "^2.1.0",
    "p-queue": "^8.1.1",
    "p-retry": "^7.0.0",
    "pg": "8.22.0",
    "redis": "^5.8.2",
    "undici": "^7.28.0",
    "uuid": "^13.0.0",
    "ws": "^8.21.0",
    "zod": "4.1.5"
  }
}
