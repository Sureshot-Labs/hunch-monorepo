# Production Environment Configuration for Hunch Platform
# Copy this file to .env.prod and update with your actual values

# Database Configuration
POSTGRES_PASSWORD=your-secure-postgres-password
DATABASE_URL=postgresql://hunch:your-secure-postgres-password@postgres:5432/hunch

# Redis Configuration
REDIS_PASSWORD=your-secure-redis-password
REDIS_URL=redis://:your-secure-redis-password@redis:6379

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-at-least-32-characters-long

# CORS Configuration
CORS_ORIGIN=https://your-domain.com

# Exchange API Keys
POLYMARKET_API_KEY=your-polymarket-api-key
LIMITLESS_API_KEY=your-limitless-api-key
# Kalshi API key is stored in kalshiKey.txt file

# Alert Configuration
ALERT_EMAIL=admin@your-domain.com
ALERT_SLACK_WEBHOOK=https://hooks.slack.com/services/YOUR/SLACK/WEBHOOK
ALERT_PAGERDUTY_KEY=your-pagerduty-integration-key

# SMTP Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_SECURE=false

# Grafana Configuration
GRAFANA_PASSWORD=your-secure-grafana-password

# Docker Registry (optional)
DOCKER_REGISTRY=your-registry.com/hunch
IMAGE_TAG=latest

# Monitoring Configuration
MONITORING_ALERT_INTERVAL=10
MONITORING_ALERT_COOLDOWN=5
MONITORING_ALERT_MAX_RETRIES=3

# Retention Configuration
MONITORING_METRICS_RETENTION=30
MONITORING_ALERTS_RETENTION=90
MONITORING_LOGS_RETENTION=7

# Service Ports
API_PORT=3000
TRADING_ENGINE_PORT=3001
TRADING_ENGINE_HEALTH_PORT=3002
ANALYTICS_ENGINE_PORT=3003
WEBHOOK_SYSTEM_PORT=3004
PRICE_HISTORY_PORT=3005
DATA_INGESTION_PORT=3006
MONITORING_PORT=3007
MONITORING_METRICS_PORT=9090

# Performance Configuration
RATE_LIMIT_WINDOW=900000
RATE_LIMIT_MAX=100
CACHE_TTL=300
ANALYSIS_TIMEOUT=30000
MAX_CONCURRENT_DELIVERIES=100
DELIVERY_TIMEOUT=30000
RETRY_MAX_ATTEMPTS=3
COLLECTION_INTERVAL=60000
BATCH_SIZE=1000
QUEUE_CONCURRENCY=10
RATE_LIMIT_PER_MINUTE=60

# Health Check Configuration
HEALTH_CHECK_TIMEOUT=5000
HEALTH_CHECK_INTERVAL=30
ENABLE_HEALTH_CHECK=true

# Logging Configuration
LOG_LEVEL=info
LOG_FORMAT=json

# SSL Configuration (for HTTPS)
SSL_CERT_PATH=/etc/nginx/ssl/cert.pem
SSL_KEY_PATH=/etc/nginx/ssl/key.pem

# Backup Configuration
BACKUP_SCHEDULE=0 2 * * *
BACKUP_RETENTION_DAYS=30
BACKUP_S3_BUCKET=your-backup-bucket
BACKUP_S3_REGION=us-east-1
BACKUP_S3_ACCESS_KEY=your-s3-access-key
BACKUP_S3_SECRET_KEY=your-s3-secret-key
