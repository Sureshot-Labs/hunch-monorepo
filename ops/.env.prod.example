NODE_ENV=production
HOST=0.0.0.0
PORT=3001
LOG_LEVEL=info

PGUSER=hunch
PGPASSWORD=change_me
PGDATABASE=hunch
PGPORT=5432
PGDATA_DIR=/opt/hunch-data/postgres

REDIS_PORT=6379
REDIS_DATA_DIR=/opt/hunch-data/redis

DATABASE_URL=postgresql://hunch:change_me@postgres:5432/hunch
REDIS_URL=redis://redis:6379

# Secrets Manager rollout is opt-in. Deploy with off, switch to optional, then
# strict after AWS bundles are populated and plaintext secrets are removed.
HUNCH_SECRETS_MODE=off
HUNCH_SECRET_BUNDLES=
HUNCH_SECRET_REQUIRED_KEYS=
AWS_REGION=eu-north-1

NGINX_SERVER_NAME=api.hunch.trade
NGINX_PROXY_READ_TIMEOUT=3600
NGINX_PROXY_SEND_TIMEOUT=3600
NGINX_LOG_DIR=/opt/hunch-data/nginx
NGINX_SSL_CERT=/etc/letsencrypt/live/api.hunch.trade/fullchain.pem
NGINX_SSL_KEY=/etc/letsencrypt/live/api.hunch.trade/privkey.pem
NGINX_APP_SERVER_NAME=app.hunch.trade
# Use separate certs for app (recommended). If using a single SAN/wildcard cert,
# set these to the same paths as NGINX_SSL_CERT/NGINX_SSL_KEY.
NGINX_APP_SSL_CERT=/etc/letsencrypt/live/app.hunch.trade/fullchain.pem
NGINX_APP_SSL_KEY=/etc/letsencrypt/live/app.hunch.trade/privkey.pem

PRIVY_APP_ID=
PRIVY_APP_SECRET=
PRIVY_WEBHOOK_SECRET=
CREDENTIALS_ENCRYPTION_KEY=
RELAY_API_KEY=
FUNDING_REFERENCE_LOOKUP_HMAC_KEY=
FUNDING_REFERENCE_LOOKUP_KEY_VERSION=1
RELAY_REQUEST_TIMEOUT_MS=10000
JWT_SECRET=
JWT_EXPIRES_IN=24h
TRUST_PROXY=true
TRUST_PROXY_HOPS=1
# Required when TRUST_PROXY=true (frontend proxy must forward this exact secret)
HUNCH_PROXY_SECRET=
METRICS_AUTH_TOKEN=

# Telegram Mini App. Keep disabled until BotFather and Privy Telegram settings
# are configured for the production app domain.
HUNCH_TELEGRAM_MINI_APP_ENABLED=false
HUNCH_TELEGRAM_BOT_TOKEN=
HUNCH_TELEGRAM_MEMBERSHIP_BOT_ID=8822816999
HUNCH_TELEGRAM_MEMBERSHIP_CHAT_ID=-1003910565409
HUNCH_TELEGRAM_INIT_DATA_MAX_AGE_SECONDS=300
HUNCH_TELEGRAM_NEW_USERS_ENABLED=false
# Runtime Telegram trading also requires HUNCH_FINANCE_WORKER_ENABLED=true and
# both the API venue-aware and finance DB-only reconcilers below.
HUNCH_TELEGRAM_VENUE_RECONCILE_ENABLED=false
HUNCH_TELEGRAM_VENUE_RECONCILE_INTERVAL_SEC=60
HUNCH_TELEGRAM_VENUE_RECONCILE_BATCH_SIZE=5
HUNCH_FINANCE_TELEGRAM_TRADE_INTENTS_ENABLED=false
HUNCH_FINANCE_TELEGRAM_TRADE_INTENTS_INTERVAL_SEC=60
HUNCH_FINANCE_TELEGRAM_TRADE_INTENTS_EXECUTING_GRACE_SEC=600

# Admin auth. Keep legacy fallback enabled until the separate admin panel fully
