NODE_ENV=production
HOST=0.0.0.0
PORT=3001
LOG_LEVEL=info

PGUSER=hunch
PGPASSWORD=change_me
PGDATABASE=hunch
PGPORT=5432
PGDATA_DIR=/opt/hunch-data/postgres

REDIS_PORT=6379
REDIS_DATA_DIR=/opt/hunch-data/redis

DATABASE_URL=postgresql://hunch:change_me@postgres:5432/hunch
REDIS_URL=redis://redis:6379

NGINX_SERVER_NAME=api.hunch.trade
NGINX_PROXY_READ_TIMEOUT=3600
NGINX_PROXY_SEND_TIMEOUT=3600
NGINX_LOG_DIR=/opt/hunch-data/nginx
NGINX_SSL_CERT=/etc/letsencrypt/live/api.hunch.trade/fullchain.pem
NGINX_SSL_KEY=/etc/letsencrypt/live/api.hunch.trade/privkey.pem
NGINX_APP_SERVER_NAME=app.hunch.trade
# Use separate certs for app (recommended). If using a single SAN/wildcard cert,
# set these to the same paths as NGINX_SSL_CERT/NGINX_SSL_KEY.
NGINX_APP_SSL_CERT=/etc/letsencrypt/live/app.hunch.trade/fullchain.pem
NGINX_APP_SSL_KEY=/etc/letsencrypt/live/app.hunch.trade/privkey.pem

PRIVY_APP_ID=
