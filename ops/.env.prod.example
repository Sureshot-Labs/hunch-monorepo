ADMIN_AUTH_LEGACY_FALLBACK=true
ADMIN_APP_BASE_URL=https://admin.hunch.trade
ADMIN_ENROLLMENT_TTL_MS=259200000
ADMIN_SESSION_TTL_MS=28800000
