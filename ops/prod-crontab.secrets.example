# Example prod cron entries after enabling the secret-aware launcher.
# Keep these synchronized with the host crontab on the EC2 instance.
# These run inside hunch-api, so hunch-api must load every bundle required by
# these scripts through HUNCH_SECRET_BUNDLES_API.

25 */8 * * * /usr/bin/flock -n /tmp/hunch-ai-cluster.lock /usr/bin/docker exec hunch-api node /app/packages/config/dist/run-with-secrets.js /app/apps/api/dist/ai-embed-cluster.js >> /opt/hunch-data/logs/ai-cluster.log 2>&1
0 * * * * /usr/bin/flock -n /tmp/hunch-wallet-intel.lock /usr/bin/timeout 55m /usr/bin/docker exec hunch-api node /app/packages/config/dist/run-with-secrets.js /app/apps/api/dist/wallet-intel-refresh.js >> /opt/hunch-data/logs/wallet-intel.log 2>&1
20 */12 * * * /usr/bin/flock -n /tmp/hunch-whale-profiles.lock /usr/bin/docker exec hunch-api node /app/packages/config/dist/run-with-secrets.js /app/apps/api/dist/ai-wallet-profiles.js >> /opt/hunch-data/logs/whale-profiles.log 2>&1
30 4 * * * /usr/bin/flock -n /tmp/hunch-kalshi-mint-audit.lock /usr/bin/docker exec hunch-api node /app/packages/config/dist/run-with-secrets.js /app/apps/api/dist/kalshi-mint-audit.js --limit=80000 --batch=500 --delay=50 --retry=2 --backoff=250 >> /opt/hunch-data/logs/kalshi-mint-audit.log 2>&1
10 */6 * * * /usr/bin/flock -n /tmp/hunch-ai-map-pipeline.lock /bin/bash -lc '/usr/bin/docker exec hunch-api node /app/packages/config/dist/run-with-secrets.js /app/apps/api/dist/ai-map-build-runner.js >> /opt/hunch-data/logs/ai-map-build.log 2>&1 && /usr/bin/docker exec hunch-api node /app/packages/config/dist/run-with-secrets.js /app/apps/api/dist/ai-map-search-runner.js >> /opt/hunch-data/logs/ai-map-search.log 2>&1 && /usr/bin/docker exec hunch-api node /app/packages/config/dist/run-with-secrets.js /app/apps/api/dist/ai-map-signals-runner.js >> /opt/hunch-data/logs/ai-map-signals.log 2>&1'
37 3 * * * /usr/bin/flock -n /tmp/hunch-analytics-retention.lock /usr/bin/docker exec hunch-api node /app/packages/config/dist/run-with-secrets.js /app/apps/api/dist/analytics-retention.js --retention-days=395 --limit=50000 --statement-timeout-sec=120 >> /opt/hunch-data/logs/analytics-retention.log 2>&1

# Market maintenance owns the venue cleanup matrix. When adding a venue, update
# ops/market-maintenance.sh plus the TS script allowlists and source cleanup path.
# Replaces the old /opt/hunch-data/bin/market-cleanup.sh host script.
15 5 * * * /usr/bin/flock -n /tmp/hunch-market-cleanup.lock /home/ubuntu/hunch-monorepo/ops/market-maintenance.sh --execute --no-flock >> /opt/hunch-data/logs/market-maintenance.log 2>&1
