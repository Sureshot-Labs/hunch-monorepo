# Live Polymarket Trading Test Configuration
# Copy this file to .env and fill in your actual values

# API Configuration
API_BASE_URL=http://localhost:3000

# Your Wallet Keys for Testing (REQUIRED)
# Get these from MetaMask or your wallet
TEST_PRIVATE_KEY=0x1234567890abcdef1234567890abcdef1234567890abcdef1234567890abcdef
TEST_PUBLIC_KEY=0x742d35Cc6634C0532925a3b8D4C9db96C4b4d8b6

# Database Configuration (if needed)
