# ---------- AI embeddings ----------
OPENROUTER_EMBED_MODEL=intfloat/e5-large-v2
AI_EMBED_ENABLED=true
AI_EMBED_STREAM_KEY=ai:embed:queue:active
AI_EMBED_GROUP=ai-embedder
AI_EMBED_CONSUMER=ai-worker-local
AI_EMBED_BATCH_SIZE=50
AI_EMBED_CONCURRENCY=4
AI_EMBED_BLOCK_MS=2000
AI_EMBED_LOG_INTERVAL_MS=10000
AI_EMBED_STREAM_MAXLEN=200000
AI_EMBED_TEXT_VERSION=v3
AI_EMBED_TTL_SEC=172800
AI_EMBED_MAX_CHARS=1500
AI_EMBED_DESC_MAX_CHARS=500
AI_EMBED_TOP_MARKETS_MAX_CHARS=320

# ---------- AI cluster analysis ----------
AI_CLUSTER_ANALYSIS_ENABLED=false
AI_CLUSTER_MODEL_FAST=openai/gpt-5-nano
AI_CLUSTER_MODEL_FINAL=openai/gpt-5.2
AI_CLUSTER_MODEL_FALLBACK=openai/gpt-4o-mini
AI_CLUSTER_MAX_STAGE_B=50
AI_CLUSTER_REANALYZE_HOURS=24
AI_CLUSTER_USE_WEB_CONTEXT=false
AI_CLUSTER_WEB_MAX_RESULTS=5
AI_CLUSTER_MIN_CONFIDENCE=0.6
AI_CLUSTER_MAX_OUTLIER_RATIO=0.4
AI_CLUSTER_ANALYSIS_MIN_SPREAD=0.02
AI_CLUSTER_ANALYSIS_MIN_QUALITY=0.45
AI_CLUSTER_ANALYSIS_MIN_VENUE_COUNT=2
AI_CLUSTER_ANALYSIS_CONCURRENCY=3
AI_CLUSTER_DEBUG_LOGS=false
